# MCP Servers Environment Variables
# Copy to .env and fill in your values
# Used by: ./install.sh --from-env

# Google Gemini API Key (for nanobanana-mcp + veo-mcp)
# Get yours at: https://aistudio.google.com/
GOOGLE_API_KEY=

# Brave Search API Key (for brave-search)
# Get yours at: https://brave.com/search/api/
BRAVE_API_KEY=

# Google Maps API Key (for maps-grounding-lite)
# Get yours at: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=

# Obsidian Vault Path (for obsidian MCP)
# Example: ~/Obsidian Vault/My Vault
OBSIDIAN_VAULT=

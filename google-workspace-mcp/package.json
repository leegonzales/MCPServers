{
  "name": "google-workspace-mcp",
  "version": "1.0.0",
  "description": "Multi-account Google Workspace MCP server (wraps gemini-cli-extensions/workspace fork)",
  "main": "dist/index.js",
  "bin": {
    "google-workspace-mcp": "dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:personal": "WORKSPACE_PROFILE=personal node dist/index.js",
    "start:catalyst": "WORKSPACE_PROFILE=catalyst node dist/index.js",
    "dev": "tsc --watch",
    "setup": "node scripts/setup.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "google-workspace",
    "gmail",
    "calendar",
    "drive",
    "docs",
    "sheets",
    "claude"
  ],
  "author": "Lee Gonzales",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leegonzales/MCPServers.git",
    "directory": "google-workspace-mcp"
  },
  "homepage": "https://github.com/leegonzales/MCPServers/tree/main/google-workspace-mcp#readme",
  "bugs": {
    "url": "https://github.com/leegonzales/MCPServers/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  }
}
